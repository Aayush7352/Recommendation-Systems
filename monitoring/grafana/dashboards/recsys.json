{
  "title": "RecSys Platform",
  "tags": ["recsys", "mlops"],
  "schemaVersion": 38,
  "panels": [
    {
      "title": "Request Rate",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(recsys_requests_total[5m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "title": "Request Latency (P99)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(recsys_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Recommendations Served",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(recsys_recommendations_total[5m])",
          "legendFormat": "{{domain}} - {{algo}}"
        }
      ]
    }
  ]
}
